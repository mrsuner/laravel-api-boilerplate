# -----------------------------------------------------------------------------
# Local docker-compose overrides
# -----------------------------------------------------------------------------
# Copy this file to docker/.env.docker and tweak as needed for your machine.
# Compose loads it via `env_file:` on each service in docker-compose.yml.
#
# Laravel application settings (APP_KEY, mail, etc.) still live in the project
# root `.env` — both files are loaded together.
# -----------------------------------------------------------------------------

# Host UID/GID baked into the dev image so bind-mounted files stay writable.
# Run `id -u` / `id -g` to get yours; defaults to 1000.
WWW_USER_ID=1000
WWW_GROUP_ID=1000

# Host port that Caddy is reachable on (http://localhost:<port>).
CADDY_HTTP_PORT=8080

# Optional host port forwards for direct DB / Redis access from the host.
DB_FORWARD_PORT=5432
REDIS_FORWARD_PORT=6379

# Xdebug: off | develop | debug | debug,develop
# Leave off unless you're actively stepping through code.
XDEBUG_MODE=off

# -----------------------------------------------------------------------------
# Laravel connection settings — these override values in .env so the app talks
# to the compose services by their service names. Keep these in sync if you
# rename services in docker-compose.yml.
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# -----------------------------------------------------------------------------
# Queue worker tuning — consumed by the `command:` of the queue service.
# -----------------------------------------------------------------------------
QUEUE_TRIES=3
QUEUE_TIMEOUT=90
QUEUE_SLEEP=3
QUEUE_MAX_JOBS=1000
QUEUE_MAX_TIME=3600
QUEUE_BACKOFF=5
