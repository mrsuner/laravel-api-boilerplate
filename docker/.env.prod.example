# -----------------------------------------------------------------------------
# Production docker-compose overrides
# -----------------------------------------------------------------------------
# Copy this file to docker/.env.prod and fill in real values before deploying.
# Never commit the populated file — it contains application secrets.
#
# Compose invocation:
#   docker compose --env-file docker/.env.prod \
#                  -f docker/docker-compose.prod.yml up -d
# -----------------------------------------------------------------------------

# Image coordinates — set APP_IMAGE to your registry path (e.g. ghcr.io/org/app)
# and bump APP_IMAGE_TAG per release.
APP_IMAGE=ghcr.io/your-org/laravel-api-boilerplate
APP_IMAGE_TAG=latest

# Domain Caddy will serve and request a TLS certificate for.
APP_DOMAIN=api.example.com
ACME_EMAIL=ops@example.com

# Run pending migrations on app container boot. Only the `app` service reads
# this; queue and scheduler are pinned to RUN_MIGRATIONS=0 in the compose
# file so workers can't race the migration.
RUN_MIGRATIONS=1

# Queue worker tuning — consumed by the `command:` of the queue service.
QUEUE_TRIES=3
QUEUE_TIMEOUT=90
QUEUE_SLEEP=3
QUEUE_MAX_JOBS=1000
QUEUE_MAX_TIME=3600
QUEUE_BACKOFF=5

# -----------------------------------------------------------------------------
# Laravel application — these override the .env baked into the image.
# -----------------------------------------------------------------------------
APP_NAME=Laravel
APP_ENV=production
APP_KEY=base64:CHANGE_ME
APP_DEBUG=false
APP_URL=https://api.example.com

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Database (consumed by both Laravel and the postgres service).
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=CHANGE_ME

# Redis (consumed by both Laravel and the redis service).
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Mail / 3rd-party — populate as needed.
MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=https://app.example.com
SOCIALITE_CALLBACK_URL=https://app.example.com/auth/callback
